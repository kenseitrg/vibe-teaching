#  be added to the global gitignore or merged into this project gitignore.  For a PyCharm
#  project, uncomment the following lines or add the JetBrains template.
#.idea/

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Project-specific
# Ignore large raw data files by default; track selectively with git add -f if needed
*.segy
*.sgy
*.segd
*.su
*.raw

# Ignore generated PDFs (e.g., compiled lecture notes) by default.
# Source papers/textbooks in papers/ are also ignored to avoid committing large/copyrighted files.
*.pdf

# Ignore presentations and documents in the paper library.
*.ppt
*.pptx
*.doc
*.docx
*.zip
*.djvu
*.djv
*.odt
# Ignore locally extracted raw text from source documents (can be regenerated).
wiki/sources/_raw_text/

# Vendored tools and downloaded OCR models
/tools/llama.cpp/
/models/
*.gguf

# If you want to keep a specific source document in version control, force-add it:
# git add -f papers/textbooks/some-book.pdf

